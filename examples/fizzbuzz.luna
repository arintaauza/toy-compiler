// FizzBuzz - Classic programming challenge
// Demonstrates control flow and modulo operator

fn main() -> int {
    let i: int = 1;

    while i <= 100 {
        if i % 15 == 0 {
            print("FizzBuzz");
        } else if i % 3 == 0 {
            print("Fizz");
        } else if i % 5 == 0 {
            print("Buzz");
        } else {
            print(i);
        }

        i = i + 1;
    }

    return 0;
}
